# SmartCS ResolutionOps Console
APP_ENV=local
LOG_LEVEL=INFO
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
DEMO_HEADER_AUTH_ENABLED=true
AUTH_TOKEN_SECRET=local-demo-secret-change-me
AGENT_RUNTIME=langgraph

# LLM
# The repository runs in deterministic mock mode by default.
# To use a real OpenAI-compatible endpoint, set LLM_PROVIDER=openai-compatible
# and provide OPENAI_API_KEY plus OPENAI_BASE_URL/OPENAI_API_BASE.
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434
LLM_TIMEOUT_S=8
MOCK_MODE=true

# Embeddings / RAG
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=smartcs_kb
QDRANT_VECTOR_SIZE=384

# Optional semantic local embeddings:
# EMBEDDING_PROVIDER=sentence-transformers
# EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# QDRANT_VECTOR_SIZE=512
# QDRANT_COLLECTION=smartcs_kb_bge_small_zh

# Runtime stores
DATA_BACKEND=postgres
KB_BACKEND=qdrant
REDIS_BACKEND=redis
RATE_LIMIT_PER_MINUTE=30
DATABASE_URL=postgresql+psycopg://smartcs:smartcs@localhost:5432/smartcs
REDIS_URL=redis://localhost:6379/0

# Observability
OTEL_SERVICE_NAME=smartcs-agent-desk
OTEL_EXPORTER_OTLP_ENDPOINT=
