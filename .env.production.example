APP_ENV=production
DEMO_HEADER_AUTH_ENABLED=false
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=https://your-smartcs-frontend.example.com
CORS_ALLOW_CREDENTIALS=true
AGENT_RUNTIME=langgraph
DATA_BACKEND=postgres
REDIS_BACKEND=redis
KB_BACKEND=qdrant
DATABASE_URL=postgresql+psycopg://smartcs:change-me@postgres:5432/smartcs
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
LLM_PROVIDER=mock
LLM_TIMEOUT_S=8
MOCK_MODE=true
