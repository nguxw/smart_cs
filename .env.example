# SmartCS Agent Desk
APP_ENV=local
LOG_LEVEL=INFO

# LLM: copy this file to .env and fill your real key.
# Use mock when you want to run without API cost.
LLM_PROVIDER=openai-compatible
LLM_MODEL=mimo-v2.5-pro
MODEL_NAME=mimo-v2.5-pro
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
OLLAMA_BASE_URL=http://localhost:11434
MOCK_MODE=false

# Embeddings / RAG
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=smartcs_kb

# Runtime stores
DATA_BACKEND=postgres
KB_BACKEND=qdrant
REDIS_BACKEND=redis
RATE_LIMIT_PER_MINUTE=30
DATABASE_URL=postgresql+psycopg://smartcs:smartcs@localhost:5432/smartcs
REDIS_URL=redis://localhost:6379/0

# Observability
OTEL_SERVICE_NAME=smartcs-agent-desk
OTEL_EXPORTER_OTLP_ENDPOINT=
